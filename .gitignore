# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems
.DocumentRevisions-V100

# .the-grid session ephemera
# Tracked: .the-grid/sessions/context_bundles/, summaries/, index.jsonl
# Ignored below: beacons/ (ephemeral signals), hook_logs/ (per-process runtime noise)
.the-grid/sessions/beacons/
.the-grid/sessions/hook_logs/

# Preview server runtime state (managed by tools/scripts/preview.sh)
.the-grid/preview.pid
.the-grid/preview.log

# Preview server build output (rebuilt on each `preview.sh start`)
tools/preview/preview

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Node dev toolchain (Playwright)
node_modules/

# Visual QA output — ephemeral
playwright-report/
test-results/
screenshots/

# Local mockup previews — symlinks into docs/dev/mockups/, dev-only
# Keeps site/ publishable-clean while exposing mockups through the preview server
site/_mockups/

# Visual-review captures — rag-web-visual-reviewer workspace, overwritten
# per review. The verdict is the evidence; the PNGs are working state.
.the-grid/review-screenshots/
